<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.ShopManagementController">

    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="Tableau de bord" styleClass="nav-button" onAction="#handleDashboard"/>
                <Button text="Gerer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="Gerer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="Gerer Examens" styleClass="nav-button" onAction="#handleManageExams"/>
                <Button text="Boutique" styleClass="nav-button active" onAction="#handleShopManagement"/>
                <Button text="Bulletins" styleClass="nav-button" onAction="#handleBulletins"/>
                <Button text="Certifications" styleClass="nav-button" onAction="#handleCertifications"/>
                <Button text="Analyse AI" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="Gestion des Eleves" styleClass="nav-button" onAction="#handleStudentManagement"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="Deconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" pannable="true" styleClass="content-scroll">
            <HBox styleClass="content-area" spacing="16">

                <VBox spacing="16" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Gestion Boutique" styleClass="page-title" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalProductsLabel" style="-fx-text-fill: #64748B;"/>
                        <Button text="Categories" onAction="#handleManageCategories" styleClass="btn-secondary"/>
                        <TextField fx:id="searchField" promptText="Rechercher..." styleClass="search-bar" onAction="#handleSearch"/>
                    </HBox>

                    <Label fx:id="messageLabel" visible="false" wrapText="true"/>

                    <TableView fx:id="productsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="idColumn" text="ID" prefWidth="55"/>
                            <TableColumn fx:id="nameColumn" text="Nom" prefWidth="200"/>
                            <TableColumn fx:id="priceColumn" text="Prix" prefWidth="90"/>
                            <TableColumn fx:id="stockColumn" text="Stock" prefWidth="70"/>
                            <TableColumn fx:id="imageColumn" text="Image" prefWidth="140"/>
                            <TableColumn fx:id="categoryNameColumn" text="Categorie" prefWidth="130"/>
                        </columns>
                        <placeholder>
                            <Label text="Aucun produit" style="-fx-text-fill: #94A3B8;"/>
                        </placeholder>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="12" minWidth="300" prefWidth="320" maxWidth="360">
                    <Label text="Formulaire Produit" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                    <Separator/>

                    <VBox spacing="4">
                        <Label text="Nom *" styleClass="form-label"/>
                        <TextField fx:id="nameField" promptText="Nom du produit" styleClass="text-field"/>
                    </VBox>

                    <HBox spacing="8">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Prix *" styleClass="form-label"/>
                            <TextField fx:id="priceField" promptText="0.00" styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Stock *" styleClass="form-label"/>
                            <TextField fx:id="stockField" promptText="0" styleClass="text-field"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4">
                        <Label text="Categorie *" styleClass="form-label"/>
                        <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="image (chemin / URL)" styleClass="form-label"/>
                        <TextField fx:id="imageField" promptText="Optionnel" styleClass="text-field"/>
                    </VBox>

                    <Separator/>
                    <HBox spacing="8">
                        <Button text="Creer" onAction="#handleCreate" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Modifier" onAction="#handleUpdate" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <HBox spacing="8">
                        <Button text="Supprimer" onAction="#handleDelete" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Effacer" onAction="#handleClear" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>

            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
