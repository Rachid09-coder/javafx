<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.BulletinsController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard"/>
                <Button text="📚  Gérer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="📦  Gérer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="📝  Gérer Examens" styleClass="nav-button" onAction="#handleManageExams"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShopManagement"/>
                <Button text="📊  Bulletins" styleClass="nav-button active" onAction="#handleBulletins"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertifications"/>
                <Button text="🤖  Analyse AI" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="👥  Gestion des Élèves" styleClass="nav-button" onAction="#handleStudentManagement"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" pannable="true" styleClass="content-scroll">
            <HBox styleClass="content-area" spacing="16">

                <VBox spacing="16" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Gestion des Bulletins" styleClass="page-title" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="searchField" promptText="🔍 Rechercher..." styleClass="search-bar" onAction="#handleSearch"/>
                    </HBox>

                    <Label fx:id="messageLabel" visible="false" wrapText="true"/>

                    <TableView fx:id="bulletinsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="studentIdColumn" text="Élève ID" prefWidth="80"/>
                            <TableColumn fx:id="academicYearColumn" text="Année" prefWidth="100"/>
                            <TableColumn fx:id="semesterColumn" text="Semestre" prefWidth="100"/>
                            <TableColumn fx:id="averageColumn" text="Moyenne" prefWidth="80"/>
                            <TableColumn fx:id="statusColumn" text="Statut" prefWidth="100"/>
                            <TableColumn fx:id="mentionColumn" text="Mention" prefWidth="120"/>
                        </columns>
                        <placeholder>
                            <Label text="Aucun bulletin" style="-fx-text-fill: #94A3B8;"/>
                        </placeholder>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="10" minWidth="320" prefWidth="360" maxWidth="400">
                    <Label text="Formulaire Bulletin" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                    <Separator/>

                    <VBox spacing="4">
                        <Label text="Élève (student_id) *" styleClass="form-label"/>
                        <TextField fx:id="studentIdField" promptText="ID numérique" styleClass="text-field"/>
                    </VBox>

                    <HBox spacing="8">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Année académique *" styleClass="form-label"/>
                            <TextField fx:id="academicYearField" promptText="ex: 2025/2026" styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Semestre *" styleClass="form-label"/>
                            <TextField fx:id="semesterField" promptText="ex: S1" styleClass="text-field"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="8">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Moyenne" styleClass="form-label"/>
                            <TextField fx:id="averageField" promptText="Optionnel" styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Statut *" styleClass="form-label"/>
                            <ComboBox fx:id="statusComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4">
                        <Label text="Mention *" styleClass="form-label"/>
                        <TextField fx:id="mentionField" promptText="ex: Bien, Très bien..." styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Rang (class_rank)" styleClass="form-label"/>
                        <TextField fx:id="classRankField" promptText="Optionnel" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="HMAC (hmac_hash)" styleClass="form-label"/>
                        <TextField fx:id="hmacHashField" promptText="Optionnel" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="PDF (pdf_path)" styleClass="form-label"/>
                        <TextField fx:id="pdfPathField" promptText="Chemin fichier PDF" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Code vérification" styleClass="form-label"/>
                        <TextField fx:id="verificationCodeField" promptText="Optionnel" styleClass="text-field"/>
                    </VBox>

                    <Label text="Dates (yyyy-MM-dd HH:mm:ss), optionnel" styleClass="form-label"/>

                    <HBox spacing="8">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="validé le" styleClass="form-label"/>
                            <TextField fx:id="validatedAtField" styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="publié le" styleClass="form-label"/>
                            <TextField fx:id="publishedAtField" styleClass="text-field"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4">
                        <Label text="révoqué le" styleClass="form-label"/>
                        <TextField fx:id="revokedAtField" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Motif révocation" styleClass="form-label"/>
                        <TextArea fx:id="revocationReasonArea" promptText="Optionnel" styleClass="text-area" prefRowCount="2" wrapText="true"/>
                    </VBox>

                    <HBox spacing="8">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Validé par (id)" styleClass="form-label"/>
                            <TextField fx:id="validatedByIdField" styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Publié par (id)" styleClass="form-label"/>
                            <TextField fx:id="publishedByIdField" styleClass="text-field"/>
                        </VBox>
                    </HBox>

                    <Separator/>
                    <HBox spacing="8">
                        <Button text="➕ Créer" onAction="#handleCreate" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="✏ Modifier" onAction="#handleUpdate" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <HBox spacing="8">
                        <Button text="🗑 Supprimer" onAction="#handleDelete" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="✖ Effacer" onAction="#handleClear" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>

            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
