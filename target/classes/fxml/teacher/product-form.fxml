<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.edusmart.controller.teacher.ProductFormController"
      spacing="16" prefWidth="440" style="-fx-padding:24; -fx-background-color:#F8FAFC;">

    <Label fx:id="titleLabel" text="Nouveau Produit"
           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1E3A8A;"/>

    <Separator/>

    <VBox spacing="4">
        <Label text="Nom *" styleClass="form-label"/>
        <TextField fx:id="nameField" promptText="Nom du produit" styleClass="text-field"/>
        <Label fx:id="nameError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Prix (DT) *" styleClass="form-label"/>
            <TextField fx:id="priceField" promptText="Ex: 29.99" styleClass="text-field"/>
            <Label fx:id="priceError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Stock *" styleClass="form-label"/>
            <TextField fx:id="stockField" promptText="Ex: 100" styleClass="text-field"/>
            <Label fx:id="stockError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
    </HBox>

    <VBox spacing="4">
        <Label text="Catégorie *" styleClass="form-label"/>
        <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" styleClass="combo-box"
                  promptText="Sélectionner une catégorie..."/>
        <Label fx:id="categoryError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Image (URL/chemin)" styleClass="form-label"/>
        <TextField fx:id="imageField" promptText="Chemin ou URL de l'image" styleClass="text-field"/>
    </VBox>

    <Label fx:id="globalError" styleClass="error-label" wrapText="true"
           visible="false" managed="false"/>

    <Separator/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="✖ Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="✔ Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
