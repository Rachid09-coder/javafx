<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.edusmart.controller.teacher.ExamFormController"
      spacing="16" prefWidth="480" style="-fx-padding:24; -fx-background-color:#F8FAFC;">

    <Label fx:id="titleLabel" text="Nouvel Examen"
           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1E3A8A;"/>

    <Separator/>

    <VBox spacing="4">
        <Label text="Titre *" styleClass="form-label"/>
        <TextField fx:id="titleField" promptText="Titre de l'examen" styleClass="text-field"/>
        <Label fx:id="titleError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Description" styleClass="form-label"/>
        <TextArea fx:id="descriptionArea" promptText="Description..."
                  styleClass="text-area" prefHeight="70" wrapText="true"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Type" styleClass="form-label"/>
            <ComboBox fx:id="typeComboBox" maxWidth="Infinity" styleClass="combo-box"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Durée (min)" styleClass="form-label"/>
            <TextField fx:id="durationField" promptText="Ex: 90" styleClass="text-field"/>
            <Label fx:id="durationError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
    </HBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Coefficient" styleClass="form-label"/>
            <TextField fx:id="coefficientField" promptText="Ex: 2.0" styleClass="text-field"/>
            <Label fx:id="coefficientError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS" visible="false" managed="false">
            <Label text="Année académique" styleClass="form-label"/>
            <TextField fx:id="academicYearField" promptText="Ex: 2024-2025" styleClass="text-field"/>
        </VBox>
    </HBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Semestre" styleClass="form-label"/>
            <ComboBox fx:id="semesterComboBox" maxWidth="Infinity" styleClass="combo-box"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Module" styleClass="form-label"/>
            <TextField fx:id="moduleNameField" promptText="Nom du module" styleClass="text-field"/>
        </VBox>
    </HBox>

    <Label fx:id="globalError" styleClass="error-label" wrapText="true"
           visible="false" managed="false"/>

    <Separator/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="✖ Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="✔ Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
