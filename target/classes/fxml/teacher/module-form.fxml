<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.edusmart.controller.teacher.ModuleFormController"
      spacing="16" prefWidth="440" style="-fx-padding:24; -fx-background-color:#F8FAFC;">

    <Label fx:id="titleLabel" text="Nouveau Module"
           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1E3A8A;"/>

    <Separator/>

    <!-- Titre -->
    <VBox spacing="4">
        <Label text="Titre *" styleClass="form-label"/>
        <TextField fx:id="titleField" promptText="Titre du module" styleClass="text-field"/>
        <Label fx:id="titleError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <!-- Description -->
    <VBox spacing="4">
        <Label text="Description" styleClass="form-label"/>
        <TextArea fx:id="descriptionArea" promptText="Description du module..."
                  styleClass="text-area" prefHeight="80" wrapText="true"/>
    </VBox>

    <!-- Durée -->
    <VBox spacing="4">
        <Label text="Durée (heures)" styleClass="form-label"/>
        <TextField fx:id="durationField" promptText="Ex: 10" styleClass="text-field"/>
        <Label fx:id="durationError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <!-- Cours associé -->
    <VBox spacing="4">
        <Label text="Cours associé" styleClass="form-label"/>
        <ComboBox fx:id="courseComboBox" maxWidth="Infinity" styleClass="combo-box"
                  promptText="Sélectionner un cours..."/>
    </VBox>

    <!-- Message global -->
    <Label fx:id="globalError" styleClass="error-label" wrapText="true"
           visible="false" managed="false"/>

    <Separator/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="✖ Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="✔ Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
