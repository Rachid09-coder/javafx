<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.edusmart.controller.teacher.CategoryFormController"
      spacing="16" prefWidth="420" style="-fx-padding:24; -fx-background-color:#F8FAFC;">

    <Label fx:id="titleLabel" text="Nouvelle Catégorie"
           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1E3A8A;"/>

    <Separator/>

    <VBox spacing="4">
        <Label text="Nom *" styleClass="form-label"/>
        <TextField fx:id="nameField" promptText="Nom de la catégorie" styleClass="text-field"/>
        <Label fx:id="nameError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Description" styleClass="form-label"/>
        <TextArea fx:id="descriptionArea" promptText="Description optionnelle..."
                  styleClass="text-area" prefHeight="70" wrapText="true"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Icône (emoji)" styleClass="form-label"/>
            <TextField fx:id="iconField" promptText="Ex: 📚" styleClass="text-field"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Couleur (hex)" styleClass="form-label"/>
            <TextField fx:id="colorField" promptText="Ex: #1E3A8A" styleClass="text-field"/>
        </VBox>
    </HBox>

    <Label fx:id="globalError" styleClass="error-label" wrapText="true"
           visible="false" managed="false"/>

    <Separator/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="✖ Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="✔ Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
