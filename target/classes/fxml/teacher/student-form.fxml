<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.edusmart.controller.teacher.StudentFormController"
      spacing="16" prefWidth="480" style="-fx-padding:24; -fx-background-color:#F8FAFC;">

    <Label fx:id="titleLabel" text="Nouvel Utilisateur"
           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1E3A8A;"/>

    <Separator/>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Prénom *" styleClass="form-label"/>
            <TextField fx:id="firstNameField" promptText="Prénom" styleClass="text-field"/>
            <Label fx:id="firstNameError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Nom *" styleClass="form-label"/>
            <TextField fx:id="lastNameField" promptText="Nom de famille" styleClass="text-field"/>
            <Label fx:id="lastNameError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
    </HBox>

    <VBox spacing="4">
        <Label text="Email *" styleClass="form-label"/>
        <TextField fx:id="emailField" promptText="exemple@email.com" styleClass="text-field"/>
        <Label fx:id="emailError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Mot de passe *" styleClass="form-label"/>
            <PasswordField fx:id="passwordField" promptText="Min. 6 caractères" styleClass="password-field"/>
            <Label fx:id="passwordError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Téléphone" styleClass="form-label"/>
            <TextField fx:id="phoneField" promptText="Ex: 0612345678" styleClass="text-field"/>
            <Label fx:id="phoneError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
    </HBox>

    <VBox spacing="4">
        <Label text="Rôle *" styleClass="form-label"/>
        <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="combo-box"
                  promptText="Sélectionner un rôle..."/>
        <Label fx:id="roleError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <CheckBox fx:id="activeCheckBox" text="Compte actif" selected="true"/>

    <Label fx:id="globalError" styleClass="error-label" wrapText="true"
           visible="false" managed="false"/>

    <Separator/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="✖ Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="✔ Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
