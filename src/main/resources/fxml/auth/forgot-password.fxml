<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.edusmart.controller.auth.ForgotPasswordController"
            style="-fx-background-color: #f5f5f5;">

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
            <VBox alignment="TOP_CENTER" spacing="10" style="-fx-background-color: white; -fx-border-radius: 10; -fx-padding: 30;">

                <!-- Title -->
                <Label text="Récupération de mot de passe" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #333;">
                    <font>
                        <Font size="24.0"/>
                    </font>
                </Label>

                <!-- Subtitle -->
                <Label text="Entrez votre adresse email pour recevoir un code de réinitialisation"
                       style="-fx-text-fill: #666; -fx-font-size: 12; -fx-wrap-text: true;"
                       maxWidth="300"/>

                <Separator/>

                <!-- Email Input -->
                <VBox spacing="5">
                    <Label text="Adresse Email :" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="emailField" promptText="exemple@email.com"
                              style="-fx-padding: 10; -fx-font-size: 12;"/>
                </VBox>

                <!-- Info Message -->
                <Label fx:id="infoLabel" text="Un code de réinitialisation sera envoyé à votre email"
                       style="-fx-text-fill: #0066cc; -fx-font-size: 11; -fx-wrap-text: true;"
                       visible="false"/>

                <!-- Error Label -->
                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #cc0000; -fx-font-size: 11; -fx-wrap-text: true;"
                       visible="false"/>

                <!-- Success Label -->
                <Label fx:id="successLabel" text=""
                       style="-fx-text-fill: #00aa00; -fx-font-size: 11; -fx-wrap-text: true;"
                       visible="false"/>

                <Separator/>

                <!-- Buttons -->
                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="sendCodeButton" text="Envoyer le code"
                           style="-fx-padding: 10 30; -fx-font-size: 12; -fx-cursor: hand;
                                  -fx-background-color: #4CAF50; -fx-text-fill: white;
                                  -fx-border-radius: 5;"/>
                    <Button fx:id="backButton" text="Retour"
                           style="-fx-padding: 10 30; -fx-font-size: 12; -fx-cursor: hand;
                                  -fx-background-color: #808080; -fx-text-fill: white;
                                  -fx-border-radius: 5;"/>
                </HBox>

                <!-- Loading Progress -->
                <ProgressBar fx:id="progressBar" visible="false" prefWidth="100" />

            </VBox>
        </VBox>
    </center>

</BorderPane>
