<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.edusmart.controller.auth.ResetPasswordController"
            style="-fx-background-color: #f5f5f5;">

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
            <VBox alignment="TOP_CENTER" spacing="10" style="-fx-background-color: white; -fx-border-radius: 10; -fx-padding: 30;">

                <!-- Title -->
                <Label text="Réinitialiser votre mot de passe" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #333;">
                    <font>
                        <Font size="24.0"/>
                    </font>
                </Label>

                <!-- Subtitle -->
                <Label text="Entrez le code reçu et votre nouveau mot de passe"
                       style="-fx-text-fill: #666; -fx-font-size: 12; -fx-wrap-text: true;"
                       maxWidth="300"/>

                <Separator/>

                <!-- Reset Token Code -->
                <VBox spacing="5">
                    <Label text="Code de réinitialisation :" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="tokenField" promptText="Entrez le code reçu par email"
                              style="-fx-padding: 10; -fx-font-size: 12;"/>
                </VBox>

                <!-- New Password -->
                <VBox spacing="5">
                    <Label text="Nouveau mot de passe :" style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="newPasswordField" promptText="Minimum 6 caractères"
                                  style="-fx-padding: 10; -fx-font-size: 12;"/>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="5">
                    <Label text="Confirmez le mot de passe :" style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirmez votre nouveau mot de passe"
                                  style="-fx-padding: 10; -fx-font-size: 12;"/>
                </VBox>

                <!-- Password Strength Indicator -->
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Force :" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                    <ProgressBar fx:id="strengthBar" prefWidth="150" prefHeight="10"/>
                    <Label fx:id="strengthLabel" text="Faible" style="-fx-font-size: 11;"/>
                </HBox>

                <!-- Requirements -->
                <VBox spacing="3" style="-fx-border-color: #ddd; -fx-padding: 10; -fx-border-radius: 5;">
                    <Label text="Exigences :" style="-fx-font-weight: bold; -fx-font-size: 11;"/>
                    <Label fx:id="req1" text="✗ Minimum 6 caractères" style="-fx-text-fill: #cc0000; -fx-font-size: 10;"/>
                    <Label fx:id="req2" text="✗ Au moins une majuscule" style="-fx-text-fill: #cc0000; -fx-font-size: 10;"/>
                    <Label fx:id="req3" text="✗ Au moins un chiffre" style="-fx-text-fill: #cc0000; -fx-font-size: 10;"/>
                </VBox>

                <!-- Error/Success Messages -->
                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #cc0000; -fx-font-size: 11; -fx-wrap-text: true;"
                       visible="false"/>

                <Label fx:id="successLabel" text=""
                       style="-fx-text-fill: #00aa00; -fx-font-size: 11; -fx-wrap-text: true;"
                       visible="false"/>

                <Separator/>

                <!-- Buttons -->
                <HBox spacing="10" alignment="CENTER">
                    <Button fx:id="resetButton" text="Réinitialiser le mot de passe"
                           style="-fx-padding: 10 30; -fx-font-size: 12; -fx-cursor: hand;
                                  -fx-background-color: #4CAF50; -fx-text-fill: white;
                                  -fx-border-radius: 5;"/>
                    <Button fx:id="backButton" text="Retour"
                           style="-fx-padding: 10 30; -fx-font-size: 12; -fx-cursor: hand;
                                  -fx-background-color: #808080; -fx-text-fill: white;
                                  -fx-border-radius: 5;"/>
                </HBox>

                <!-- Attempts Remaining -->
                <Label fx:id="attemptsLabel" text="Tentatives restantes : 3"
                       style="-fx-font-size: 10; -fx-text-fill: #666;"/>

            </VBox>
        </VBox>
    </center>

</BorderPane>
