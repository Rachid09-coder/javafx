<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.student.BulletinController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Étudiant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="📚  Mes Cours" styleClass="nav-button" onAction="#handleCourses"/>
                <Button text="📝  Examens" styleClass="nav-button" onAction="#handleExams"/>
                <Button text="📊  Bulletin" styleClass="nav-button active" onAction="#handleBulletin"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertification"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShop"/>
                <Button text="🤖  Assistant IA" styleClass="nav-button" onAction="#handleStudentAI"/>
                <Button text="👤  Mon Profil" styleClass="nav-button" onAction="#handleProfile"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox styleClass="content-area" spacing="20">

            <!-- Glassmorphism Header -->
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="card" style="-fx-padding: 15 25;">
                <VBox spacing="2">
                    <Label text="📋 Mon Bulletin de Notes" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -edu-blue;"/>
                    <Label text="Consultez vos résultats académiques et votre progression" style="-fx-text-fill: -edu-text-muted; -fx-font-size: 13px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="10">
                    <Button fx:id="printButton" text="🖨 Imprimer" onAction="#handlePrint" styleClass="btn-secondary"/>
                    <Button fx:id="downloadButton" text="⬇ Télécharger PDF" onAction="#handleDownload" styleClass="btn-primary"/>
                </HBox>
            </HBox>

            <!-- Stats Row -->
            <HBox spacing="16">
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-alignment: center;">
                    <Label text="📊" style="-fx-font-size: 32px;"/>
                    <Label fx:id="averageLabel" text="Moyenne: --" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -edu-blue;"/>
                    <Label text="Moyenne générale" style="-fx-text-fill: -edu-text-muted;"/>
                </VBox>
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-alignment: center;">
                    <Label text="🏆" style="-fx-font-size: 32px;"/>
                    <Label fx:id="rankLabel" text="Rang: --" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -edu-blue;"/>
                    <Label text="Classement" style="-fx-text-fill: -edu-text-muted;"/>
                </VBox>
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS" style="-fx-alignment: center; -fx-border-color: #7C3AED; -fx-border-radius: 12; -fx-border-width: 2;">
                    <Label text="💼" style="-fx-font-size: 32px;"/>
                    <Label fx:id="metierLabel" text="Métier: --" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
                    <Label text="Spécialité recommandée" style="-fx-text-fill: -edu-text-muted;"/>
                </VBox>
            </HBox>

            <!-- Filters -->
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 12 20;">
                <Label text="Filtrer par :" style="-fx-font-weight: bold; -fx-text-fill: -edu-text-muted;"/>
                <ComboBox fx:id="semesterFilter" promptText="Semestre" onAction="#handleFilterChange" styleClass="combo-box" prefWidth="150"/>
                <ComboBox fx:id="yearFilter" promptText="Année Académique" onAction="#handleFilterChange" styleClass="combo-box" prefWidth="150"/>
            </HBox>

            <!-- Grades Table Section -->
            <VBox VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 0;">
                <TableView fx:id="gradesTable" VBox.vgrow="ALWAYS" styleClass="table-view" style="-fx-background-radius: 12; -fx-border-radius: 12;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="subjectColumn" text="MATIÈRE" prefWidth="250"/>
                        <TableColumn fx:id="scoreColumn" text="NOTE (/20)" prefWidth="100"/>
                        <TableColumn fx:id="maxScoreColumn" text="COEFFICIENT" prefWidth="100"/>
                        <TableColumn fx:id="semesterColumn" text="PÉRIODE" prefWidth="150"/>
                        <TableColumn fx:id="commentColumn" text="SESSION" prefWidth="300"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="10">
                            <Label text="📭 Aucune note trouvée pour cette période" style="-fx-font-size: 16px; -fx-text-fill: -edu-text-muted;"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
