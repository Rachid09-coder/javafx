<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.student.CertificationController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Étudiant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="📚  Mes Cours" styleClass="nav-button" onAction="#handleCourses"/>
                <Button text="📝  Examens" styleClass="nav-button" onAction="#handleExams"/>
                <Button text="📊  Bulletin" styleClass="nav-button" onAction="#handleBulletin"/>
                <Button text="🏆  Certifications" styleClass="nav-button active" onAction="#handleCertification"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShop"/>
                <Button text="🤖  Assistant IA" styleClass="nav-button" onAction="#handleStudentAI"/>
                <Button text="👤  Mon Profil" styleClass="nav-button" onAction="#handleProfile"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox styleClass="content-area" spacing="20">

            <!-- Glassmorphism Header -->
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="card" style="-fx-padding: 15 25;">
                <Button text="⬅ Retour" onAction="#handleCourses" styleClass="btn-secondary"/>
                <VBox spacing="2">
                    <Label text="🏆 Mes Certifications" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -edu-blue;"/>
                    <Label text="Consultez et téléchargez vos diplômes et certificats officiels" style="-fx-text-fill: -edu-text-muted; -fx-font-size: 13px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox alignment="CENTER" style="-fx-background-color: #F1F5F9; -fx-padding: 10 20; -fx-background-radius: 8;">
                    <Label fx:id="totalCertificationsLabel" style="-fx-text-fill: -edu-blue; -fx-font-weight: bold; -fx-font-size: 16px;"/>
                </VBox>
            </HBox>

            <!-- Filters -->
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 12 20;">
                <Label text="Filtrer :" style="-fx-font-weight: bold; -fx-text-fill: -edu-text-muted;"/>
                <TextField fx:id="searchField" promptText="🔍 Rechercher (type, code)..." styleClass="search-bar" onAction="#handleSearch" prefWidth="250"/>
                <ComboBox fx:id="statusFilter" promptText="Statut" onAction="#handleFilterChange" styleClass="combo-box" prefWidth="150"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
                <FlowPane fx:id="certificationsContainer" hgap="20" vgap="20" style="-fx-background-color: transparent; -fx-padding: 10;">
                </FlowPane>
            </ScrollPane>

        </VBox>
    </center>
</BorderPane>
