<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.edusmart.controller.teacher.GradeFormController"
      spacing="16" prefWidth="440" style="-fx-padding:24; -fx-background-color:#F8FAFC;">

    <Label fx:id="titleLabel" text="Nouvelle Note"
           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1E3A8A;"/>

    <Separator/>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Étudiant *" styleClass="form-label"/>
            <ComboBox fx:id="studentComboBox" maxWidth="Infinity" styleClass="combo-box"
                      promptText="Choisir l'étudiant..."/>
            <Label fx:id="studentError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Cours" styleClass="form-label"/>
            <ComboBox fx:id="courseComboBox" maxWidth="Infinity" styleClass="combo-box"
                      promptText="Choisir le cours..."/>
        </VBox>
    </HBox>

    <VBox spacing="4" visible="false" managed="false">
        <Label text="Matière *" styleClass="form-label"/>
        <TextField fx:id="subjectField" promptText="Nom de la matière" styleClass="text-field" editable="false"/>
        <Label fx:id="subjectError" styleClass="error-label" visible="false" managed="false"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Note obtenue *" styleClass="form-label"/>
            <TextField fx:id="scoreField" promptText="Ex: 14.5" styleClass="text-field"/>
            <Label fx:id="scoreError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
    </HBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Semestre *" styleClass="form-label"/>
            <ComboBox fx:id="semesterComboBox" maxWidth="Infinity" styleClass="combo-box"/>
            <Label fx:id="semesterError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS" visible="false" managed="false">
            <Label text="Année académique" styleClass="form-label"/>
            <TextField fx:id="academicYearField" promptText="Ex: 2024-2025" styleClass="text-field"/>
        </VBox>
    </HBox>



    <Label fx:id="globalError" styleClass="error-label" wrapText="true"
           visible="false" managed="false"/>

    <Separator/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="✖ Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="✔ Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
