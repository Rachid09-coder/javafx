<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.TeacherDashboardController">

    <!-- ══ Sidebar ══════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" prefHeight="800">
            <VBox styleClass="sidebar-logo" spacing="3">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="NAVIGATION" styleClass="sidebar-section-label"/>
                <Button text="🏠   Tableau de bord"    styleClass="nav-button active" onAction="#handleDashboard"/>
                <Button text="📚   Gérer les Cours"    styleClass="nav-button"        onAction="#handleManageCourses"/>
                <Button text="📦   Gérer les Modules"  styleClass="nav-button"        onAction="#handleManageModules"/>
                <Button text="📝   Gérer Examens"      styleClass="nav-button"        onAction="#handleManageExams"/>
                <Button text="🛒   Boutique"           styleClass="nav-button"        onAction="#handleShopManagement"/>
                <Button text="📊   Bulletins"          styleClass="nav-button"        onAction="#handleBulletins"/>
                <Button text="🏆   Certifications"     styleClass="nav-button"        onAction="#handleCertifications"/>
                <Button text="🤖   Analyse AI"         styleClass="nav-button"        onAction="#handleAnalysisAI"/>
                <Button text="👥   Gestion des Élèves" styleClass="nav-button"        onAction="#handleStudentManagement"/>
            </VBox>
            <VBox styleClass="sidebar-footer">
                <Button text="🚪   Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ══ Main Content ═════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color: #F1F5F9;">

            <!-- Top header -->
            <HBox styleClass="top-header" alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Tableau de bord" styleClass="page-title"/>
                    <Label text="Vue d'ensemble de votre activité" styleClass="page-subtitle"/>
                </VBox>
            </HBox>

            <!-- Scrollable body -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: #F1F5F9; -fx-background-color: #F1F5F9; -fx-border-color: transparent;">
                <VBox styleClass="content-area" spacing="24">

                    <!-- Welcome Banner -->
                    <VBox styleClass="welcome-banner" spacing="6">
                        <Label fx:id="welcomeLabel" text="Bienvenue, Enseignant! 👋" styleClass="welcome-title"/>
                        <Label text="Voici un résumé de votre activité aujourd'hui" styleClass="welcome-subtitle"/>
                    </VBox>

                    <!-- KPI Cards Row -->
                    <VBox spacing="10">
                        <Label text="Statistiques clés" styleClass="section-title"/>
                        <HBox spacing="16">
                            <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label text="👥" styleClass="stat-icon"/>
                                <Label fx:id="studentsCountLabel" text="—" styleClass="stat-value"/>
                                <Label text="Étudiants" styleClass="stat-label"/>
                            </VBox>
                            <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label text="📚" styleClass="stat-icon"/>
                                <Label fx:id="coursesCountLabel" text="—" styleClass="stat-value"/>
                                <Label text="Cours" styleClass="stat-label"/>
                            </VBox>
                            <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label text="📝" styleClass="stat-icon"/>
                                <Label fx:id="examsCountLabel" text="—" styleClass="stat-value"/>
                                <Label text="Examens" styleClass="stat-label"/>
                            </VBox>
                            <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label text="💰" styleClass="stat-icon"/>
                                <Label fx:id="revenueLabel" text="—" styleClass="stat-value"/>
                                <Label text="Revenus" styleClass="stat-label"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Quick Actions -->
                    <VBox spacing="12">
                        <Label text="Actions rapides" styleClass="section-title"/>
                        <HBox spacing="12">
                            <Button text="➕  Nouveau cours"      onAction="#handleManageCourses"
                                    styleClass="action-btn" prefHeight="44"/>
                            <Button text="📝  Créer un examen"    onAction="#handleManageExams"
                                    styleClass="btn-purple" prefHeight="44"/>
                            <Button text="📦  Gérer les modules"  onAction="#handleManageModules"
                                    styleClass="action-btn" prefHeight="44"/>
                            <Button text="👥  Voir les élèves"    onAction="#handleStudentManagement"
                                    styleClass="action-btn" prefHeight="44"/>
                            <Button text="🤖  Analyse AI"         onAction="#handleAnalysisAI"
                                    styleClass="action-btn" prefHeight="44"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
