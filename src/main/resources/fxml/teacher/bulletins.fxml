<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.BulletinsController">

    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard"/>
                <Button text="📚  Gérer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="📦  Gérer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="📝  Gérer Examens" styleClass="nav-button" onAction="#handleManageExams"/>
                <Button text="📊  Notes" styleClass="nav-button" onAction="#handleGradeManagement"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShopManagement"/>
                <Button text="📋  Bulletins" styleClass="nav-button active" onAction="#handleBulletins"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertifications"/>
                <Button text="💼  Métiers" styleClass="nav-button" onAction="#handleMetierManagement"/>
                <Button text="🤖  Analyse AI" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="👥  Gestion des Élèves" styleClass="nav-button" onAction="#handleStudentManagement"/>
                <Button text="👤  Mon Profil" styleClass="nav-button" onAction="#handleProfile"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content-area" spacing="20">
            <!-- Glassmorphism Header -->
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="card" style="-fx-padding: 15 25;">
                <VBox spacing="2">
                    <Label text="📋 Répertoire des Bulletins" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -edu-blue;"/>
                    <Label text="Gérez les cycles académiques et la publication des résultats" style="-fx-text-fill: -edu-text-muted; -fx-font-size: 13px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="10">
                    <Button text="🔄 Recalculer Rangs" onAction="#handleRecalculateRanks" styleClass="btn-secondary"/>
                    <Button text="➕ Nouveau" onAction="#handleAdd" styleClass="btn-primary"/>
                </HBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 12 20;">
                <TextField fx:id="searchField" promptText="🔍 Rechercher étudiant..." styleClass="search-bar" HBox.hgrow="ALWAYS" prefWidth="200"/>
                <ComboBox fx:id="typeFilter" promptText="Type" styleClass="combo-box" prefWidth="100"/>
                <ComboBox fx:id="semesterFilter" promptText="Semestre" styleClass="combo-box" prefWidth="100"/>
                <TextField fx:id="rankFilter" promptText="Rang max" styleClass="search-bar" prefWidth="100"/>
                <ComboBox fx:id="statusFilter" promptText="Statut" styleClass="combo-box" prefWidth="120"/>
                <Button text="Filtrer" onAction="#applyFilters" styleClass="btn-primary" prefWidth="100"/>
            </HBox>

            <!-- Table Section -->
            <VBox VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 0;">
                <TableView fx:id="bulletinsTable" VBox.vgrow="ALWAYS" styleClass="table-view" style="-fx-background-radius: 12; -fx-border-radius: 12;">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="studentColumn" text="ÉTUDIANT"  prefWidth="220" />
                        <TableColumn fx:id="periodColumn"  text="CYCLE / SEM" prefWidth="140" />
                        <TableColumn fx:id="averageColumn" text="MOYENNE"   prefWidth="80" />
                        <TableColumn fx:id="rankColumn"    text="RANG"      prefWidth="60"  />
                        <TableColumn fx:id="statusColumn"  text="STATUT"    prefWidth="100" />
                        <TableColumn fx:id="mentionColumn" text="MENTION"   prefWidth="120" />
                        <TableColumn fx:id="actionsColumn" text="ACTIONS"    prefWidth="350" minWidth="350" />
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="10">
                            <Label text="📭 Aucun bulletin trouvé" style="-fx-font-size: 16px; -fx-text-fill: -edu-text-muted;"/>
                            <Button text="Générer les bulletins pour ce semestre" onAction="#handleAdd" styleClass="btn-secondary"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
