<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.ManageCoursesController">

    <!-- ══ Sidebar ══════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" prefHeight="800">
            <VBox styleClass="sidebar-logo" spacing="3">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>

            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="NAVIGATION" styleClass="sidebar-section-label"/>
                <Button text="🏠   Tableau de bord"      styleClass="nav-button"        onAction="#handleDashboard"/>
                <Button text="📚   Gérer les Cours"      styleClass="nav-button active" onAction="#handleManageCourses"/>
                <Button text="📦   Gérer les Modules"    styleClass="nav-button"        onAction="#handleManageModules"/>
                <Button text="📝   Gérer Examens"        styleClass="nav-button"        onAction="#handleManageExams"/>
                <Button text="🛒   Boutique"             styleClass="nav-button"        onAction="#handleShopManagement"/>
                <Button text="📊   Bulletins"            styleClass="nav-button"        onAction="#handleBulletins"/>
                <Button text="🏆   Certifications"       styleClass="nav-button"        onAction="#handleCertifications"/>
                <Button text="🤖   Analyse AI"           styleClass="nav-button"        onAction="#handleAnalysisAI"/>
                <Button text="👥   Gestion des Élèves"   styleClass="nav-button"        onAction="#handleStudentManagement"/>
            </VBox>

            <VBox styleClass="sidebar-footer">
                <Button text="🚪   Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ══ Main Content ═════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color: #F1F5F9;">

            <!-- Top header bar -->
            <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Gérer les Cours" styleClass="page-title"/>
                    <Label text="Créez, modifiez et gérez vos cours" styleClass="page-subtitle"/>
                </VBox>
                <ComboBox fx:id="sortComboBox" promptText="Trier par..." styleClass="combo-box"
                          style=" -fx-pref-width: 170;"/>
                <TextField fx:id="searchField" promptText="🔍  Rechercher un cours..."
                           styleClass="search-bar" onAction="#handleSearch"/>
                <Button text="🌙 Mode Sombre" onAction="#handleToggleTheme"
                        styleClass="btn-secondary" style="-fx-padding: 8 16; -fx-font-size: 12px;"/>
                <Button fx:id="toggleActivityBtn" text="⏱ Activité" onAction="#handleToggleActivity"
                        styleClass="btn-secondary" style="-fx-padding: 8 16; -fx-font-size: 12px;"/>
                <Button text="🤖 Assistant AI" onAction="#handleOpenChat"
                        styleClass="btn-primary" style="-fx-padding: 8 16; -fx-font-size: 12px;"/>
            </HBox>

            <!-- Body -->
            <HBox styleClass="content-area" spacing="20" VBox.vgrow="ALWAYS">

                <!-- ── Table Card ──────────────────────────────── -->
                <VBox spacing="14" HBox.hgrow="ALWAYS">

                    <!-- ── Analytics Dashboard ─────────────────────── -->
                    <HBox spacing="14">
                        <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="📚" style="-fx-font-size: 22px; -fx-background-color: rgba(79,70,229,0.12); -fx-padding: 8; -fx-background-radius: 10;"/>
                            <Label fx:id="totalCoursesStat" text="—" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #4F46E5;"/>
                            <Label text="Total Cours" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="💰" style="-fx-font-size: 22px; -fx-background-color: rgba(16,185,129,0.12); -fx-padding: 8; -fx-background-radius: 10;"/>
                            <Label fx:id="avgPriceStat" text="—" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                            <Label text="Prix Moyen" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="🏆" style="-fx-font-size: 22px; -fx-background-color: rgba(245,158,11,0.12); -fx-padding: 8; -fx-background-radius: 10;"/>
                            <Label fx:id="topModuleStat" text="—" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #B45309; -fx-wrap-text: true; -fx-text-alignment: center;"/>
                            <Label text="Module Populaire" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="⭐" style="-fx-font-size: 22px; -fx-background-color: rgba(239,68,68,0.10); -fx-padding: 8; -fx-background-radius: 10;"/>
                            <Label fx:id="avgRatingStat" text="—" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                            <Label text="Note Globale" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                    </HBox>

                    <!-- ── Status Distribution Bar ─────────────────── -->
                    <VBox styleClass="card" spacing="8" style="-fx-padding: 14 18;">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Répartition des statuts" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #0F172A;" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="activeCountLabel" text="0 actifs" style="-fx-font-size: 11px; -fx-text-fill: #059669;"/>
                            <Label text="·" style="-fx-text-fill: #94A3B8;"/>
                            <Label fx:id="draftCountLabel" text="0 brouillons" style="-fx-font-size: 11px; -fx-text-fill: #B45309;"/>
                            <Label text="·" style="-fx-text-fill: #94A3B8;"/>
                            <Label fx:id="inactiveCountLabel" text="0 inactifs" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </HBox>
                        <HBox fx:id="statusDistBar" spacing="2" prefHeight="8" style="-fx-background-radius: 6;"/>
                    </VBox>

                    <!-- Subscription Banner -->
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: linear-gradient(to right, #0F172A, #4F46E5); -fx-padding: 14 20; -fx-background-radius: 10;">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="📬  Alertes de baisses de prix" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 13px;"/>
                            <Label text="Soyez notifié dès qu'un cours baisse de prix" style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.65);"/>
                        </VBox>
                        <TextField fx:id="subscriberEmailField" promptText="votre@email.com"
                                   style="-fx-pref-width: 200; -fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.45); -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;"/>
                        <Button text="S'abonner" onAction="#handleSubscribe"
                                style="-fx-background-color: white; -fx-text-fill: #4F46E5; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Message label -->
                    <Label fx:id="messageLabel" visible="false" wrapText="true"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 14; -fx-background-radius: 8;"/>

                    <!-- Table wrapped in a card -->
                    <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS"
                          style="-fx-padding: 0; -fx-background-radius: 14; -fx-border-radius: 14;">

                        <!-- Card top bar: title + count + Export + Add button -->
                        <HBox style="-fx-padding: 14 20;  -fx-border-width: 0 0 1 0;"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="📋  Liste des cours"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; "/>
                            <Label fx:id="countLabel" text=""
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"
                                   HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            
                            <!-- Multi-criteria filters -->
                            <ComboBox fx:id="filterStatusBox" promptText="Statut" styleClass="combo-box" style="-fx-pref-width: 100; -fx-font-size: 11px;"/>
                            <ComboBox fx:id="filterModuleBox" promptText="Module" styleClass="combo-box" style="-fx-pref-width: 120; -fx-font-size: 11px;"/>
                            
                            <Button text="🧾 Exporter PDF" onAction="#handleExport"
                                    styleClass="btn-secondary" style="-fx-padding: 6 12; -fx-font-size: 12px;"/>
                            <Button text="➕  Nouveau Cours" onAction="#handleOpenAdd"
                                    styleClass="btn-primary" style="-fx-padding: 8 16; -fx-font-size: 12px;"/>
                        </HBox>

                        <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS" styleClass="table-view"
                                   style="-fx-background-radius: 0 0 14 14; -fx-border-radius: 0 0 14 14; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="favoriteColumn"    text="★"          prefWidth="35"  minWidth="35"/>
                                <TableColumn fx:id="idColumn"          text="ID"          prefWidth="55"  minWidth="50"/>
                                <TableColumn fx:id="titleColumn"       text="Titre"        prefWidth="160" minWidth="120"/>
                                <TableColumn fx:id="moduleColumn"      text="Module"       prefWidth="140" minWidth="100"/>
                                <TableColumn fx:id="priceColumn"       text="Prix"         prefWidth="70"  minWidth="60"/>
                                <TableColumn fx:id="ratingColumn"      text="Note"         prefWidth="70"  minWidth="60"/>
                                <TableColumn fx:id="createdAtColumn"   text="Créé le"      prefWidth="120" minWidth="100"/>
                                <TableColumn fx:id="statusColumn"      text="Statut"       prefWidth="100" minWidth="80"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8">
                                    <Label text="📭" style="-fx-font-size: 32px;"/>
                                    <Label text="Aucun cours trouvé"
                                           style="-fx-font-size: 13px; -fx-text-fill: #94A3B8;"/>
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>

                <!-- ── Form Panel (hidden initially, slides in from right) ── -->
                <VBox fx:id="formPanel" styleClass="form-panel" spacing="14"
                      minWidth="310" prefWidth="320" maxWidth="330"
                      visible="false" managed="false">

                    <!-- Panel header with close button -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label fx:id="formPanelIcon" text="✏️" style="-fx-font-size: 16px;"/>
                        <Label fx:id="formPanelTitle" text="Nouveau Cours"
                               styleClass="form-panel-title" HBox.hgrow="ALWAYS"/>
                        <!-- Close / slide-out button -->
                        <Button text="✕" onAction="#handleClosePanel"
                                styleClass="btn-close-panel"/>
                    </HBox>
                    <Separator/>

                    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="content-scroll" style="-fx-background: transparent; -fx-background-color: transparent;">
                        <VBox spacing="14" style="-fx-padding: 2;">
                            <!-- Titre -->
                            <VBox spacing="5">
                                <Label text="TITRE *" styleClass="form-label"/>
                                <TextField fx:id="titleField" promptText="Titre du cours" styleClass="text-field"/>
                            </VBox>

                            <!-- AI Suggestion label -->
                            <Label fx:id="aiSuggestionLabel" text="💡 Astuce: Un prix entre 30€ et 50€ est recommandé."
                                   wrapText="true"
                                   style="-fx-font-size: 11px; -fx-text-fill: #4F46E5; -fx-background-color: rgba(79,70,229,0.1); -fx-padding: 6 10; -fx-background-radius: 6;"/>

                            <!-- Prix -->
                            <VBox spacing="5">
                                <Label text="PRIX (€) *" styleClass="form-label"/>
                                <TextField fx:id="priceField" promptText="ex: 99.99" styleClass="text-field"/>
                            </VBox>

                            <!-- Coefficient -->
                            <VBox spacing="5">
                                <Label text="COEFFICIENT" styleClass="form-label"/>
                                <TextField fx:id="coefficientField" promptText="ex: 1.5" styleClass="text-field"/>
                            </VBox>

                            <!-- Description -->
                            <VBox spacing="5" VBox.vgrow="ALWAYS">
                                <Label text="DESCRIPTION" styleClass="form-label"/>
                                <TextArea fx:id="descriptionArea" promptText="Description du cours..."
                                          styleClass="text-area" prefHeight="80" wrapText="true"/>
                            </VBox>

                            <!-- Module -->
                            <VBox spacing="5">
                                <Label text="MODULE" styleClass="form-label"/>
                                <ComboBox fx:id="moduleComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                            </VBox>

                            <!-- Statut -->
                            <VBox spacing="5">
                                <Label text="STATUT" styleClass="form-label"/>
                                <ComboBox fx:id="statusComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                            </VBox>

                            <!-- Date Planifiée -->
                            <VBox spacing="5">
                                <Label text="DATE PLANIFIÉE *" styleClass="form-label"/>
                                <HBox spacing="8">
                                    <DatePicker fx:id="datePicker" promptText="JJ/MM/AAAA" styleClass="date-picker" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <TextField fx:id="timeField" promptText="HH:mm" styleClass="text-field" prefWidth="80"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </ScrollPane>

                    <Separator/>

                    <!-- Action buttons -->
                    <HBox spacing="8">
                        <Button fx:id="createBtn"  text="➕  Créer"    onAction="#handleCreate"
                                styleClass="btn-primary"   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="updateBtn"  text="✏  Modifier" onAction="#handleUpdate"
                                styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <HBox spacing="8">
                        <Button text="📋  Dupliquer" onAction="#handleDuplicate"
                                styleClass="btn-secondary"  HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-text-fill: #7C3AED; -fx-border-color: #7C3AED;"/>
                        <Button text="🗑  Supprimer" onAction="#handleDelete"
                                styleClass="btn-danger"    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <!-- ── Activity Panel ────────────────────────────────── -->
                <VBox fx:id="activityPanel" styleClass="card" spacing="10"
                      minWidth="260" prefWidth="260" maxWidth="260" VBox.vgrow="ALWAYS"
                      style="-fx-padding: 14; -fx-background-radius: 14; -fx-border-radius: 14;"
                      opacity="0">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="⏱" style="-fx-font-size: 16px;"/>
                        <Label text="Activité Récente" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    </HBox>
                    <Separator/>
                    <ListView fx:id="activityList" VBox.vgrow="ALWAYS"
                              style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                </VBox>

            </HBox>
        </VBox>
    </center>

    <!-- AI Chat Panel -->
    <right>
        <VBox fx:id="chatPanel" styleClass="card" prefWidth="350" visible="false" managed="false" spacing="12" style="-fx-margin: 24 24 24 0;">
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" styleClass="card-header">
                <Label text="🤖 Assistant Enseignant AI" styleClass="card-title" />
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#handleCloseChat" styleClass="btn-secondary" style="-fx-padding: 2 8;"/>
            </HBox>
            
            <Label fx:id="chatContextLabel" text="Contexte: Formulaire Actuel" wrapText="true" style="-fx-font-size: 11px; -fx-text-fill: #64748B; -fx-padding: 4; -fx-background-color: rgba(0,0,0,0.03); -fx-background-radius: 4;"/>
            
            <!-- Quick Actions -->
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Button text="⚡ Créer Cours" onAction="#handleAiAutoCreateCourse" style="-fx-font-size: 10px; -fx-background-color: #F3E8FF; -fx-text-fill: #7E22CE; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-weight: bold;"/>
                <Button text="Desc" onAction="#handleAiGenerateDesc" style="-fx-font-size: 10px; -fx-background-color: #DBEAFE; -fx-text-fill: #1E40AF; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                <Button text="Titre" onAction="#handleAiOptimizeTitle" style="-fx-font-size: 10px; -fx-background-color: #FEF3C7; -fx-text-fill: #92400E; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                <Button text="Idées" onAction="#handleAiModuleIdeas" style="-fx-font-size: 10px; -fx-background-color: #D1FAE5; -fx-text-fill: #065F46; -fx-border-radius: 4; -fx-background-radius: 4;"/>
            </HBox>

            <!-- Messages Container -->
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="content-scroll" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="chatMessagesContainer" spacing="12" style="-fx-padding: 4;"/>
            </ScrollPane>

            <HBox fx:id="loadingIndicatorBox" visible="false" managed="false" alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 4;">
                <ProgressIndicator prefWidth="16" prefHeight="16"/>
                <Label text="L'IA réfléchit..." style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
            </HBox>

            <!-- Input -->
            <HBox spacing="8" alignment="CENTER">
                <TextField fx:id="chatInputField" promptText="Demandez à l'IA..." HBox.hgrow="ALWAYS" styleClass="text-field" onAction="#handleSendChatMessage"/>
                <Button text="➤" onAction="#handleSendChatMessage" styleClass="btn-primary" style="-fx-padding: 8 12;"/>
            </HBox>
        </VBox>
    </right>

</BorderPane>
