<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.ManageCoursesController">

    <!-- ══ Sidebar ══════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" prefHeight="800">
            <VBox styleClass="sidebar-logo" spacing="3">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>

            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="NAVIGATION" styleClass="sidebar-section-label"/>
                <Button text="🏠   Tableau de bord"      styleClass="nav-button"        onAction="#handleDashboard"/>
                <Button text="📚   Gérer les Cours"      styleClass="nav-button active" onAction="#handleManageCourses"/>
                <Button text="📦   Gérer les Modules"    styleClass="nav-button"        onAction="#handleManageModules"/>
                <Button text="📝   Gérer Examens"        styleClass="nav-button"        onAction="#handleManageExams"/>
                <Button text="🛒   Boutique"             styleClass="nav-button"        onAction="#handleShopManagement"/>
                <Button text="📊   Bulletins"            styleClass="nav-button"        onAction="#handleBulletins"/>
                <Button text="🏆   Certifications"       styleClass="nav-button"        onAction="#handleCertifications"/>
                <Button text="🤖   Analyse AI"           styleClass="nav-button"        onAction="#handleAnalysisAI"/>
                <Button text="👥   Gestion des Élèves"   styleClass="nav-button"        onAction="#handleStudentManagement"/>
            </VBox>

            <VBox styleClass="sidebar-footer">
                <Button text="🚪   Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ══ Main Content ═════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color: #F1F5F9;">

            <!-- Top header bar -->
            <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Gérer les Cours" styleClass="page-title"/>
                    <Label text="Créez, modifiez et gérez vos cours" styleClass="page-subtitle"/>
                </VBox>
                <ComboBox fx:id="sortComboBox" promptText="Trier par..." styleClass="combo-box"
                          style=" -fx-pref-width: 170;"/>
                <TextField fx:id="searchField" promptText="🔍  Rechercher un cours..."
                           styleClass="search-bar" onAction="#handleSearch"/>
                <Button text="🌙 Mode Sombre" onAction="#handleToggleTheme"
                        styleClass="btn-secondary" style="-fx-padding: 8 16; -fx-font-size: 12px;"/>
            </HBox>

            <!-- Body -->
            <HBox styleClass="content-area" spacing="20" VBox.vgrow="ALWAYS">

                <!-- ── Table Card ──────────────────────────────── -->
                <VBox spacing="14" HBox.hgrow="ALWAYS">

                    <!-- ── Analytics Dashboard ─────────────────────── -->
                    <HBox spacing="14">
                        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="📚" style="-fx-font-size: 20px;"/>
                            <Label fx:id="totalCoursesStat" text="—" style="-fx-font-size: 18px; -fx-font-weight: bold; "/>
                            <Label text="Total Cours" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="💰" style="-fx-font-size: 20px;"/>
                            <Label fx:id="avgPriceStat" text="—" style="-fx-font-size: 18px; -fx-font-weight: bold; "/>
                            <Label text="Prix Moyen" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="🏆" style="-fx-font-size: 20px;"/>
                            <Label fx:id="topModuleStat" text="—" style="-fx-font-size: 18px; -fx-font-weight: bold; "/>
                            <Label text="Module Populaire" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="⭐" style="-fx-font-size: 20px;"/>
                            <Label fx:id="avgRatingStat" text="4.8" style="-fx-font-size: 18px; -fx-font-weight: bold; "/>
                            <Label text="Note Globale" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                    </HBox>

                    <!-- Subscription Banner -->
                    <HBox styleClass="card" spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 12 20; -fx-background-radius: 8;">
                        <Label text="📬 Alertes baisses de prix :" style="-fx-font-weight: bold;"/>
                        <TextField fx:id="subscriberEmailField" promptText="Entrez votre adresse email..." HBox.hgrow="ALWAYS" styleClass="text-field" style="-fx-pref-width: 200;"/>
                        <Button text="S'abonner" onAction="#handleSubscribe" styleClass="btn-primary"/>
                    </HBox>

                    <!-- Message label -->
                    <Label fx:id="messageLabel" visible="false" wrapText="true"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 14; -fx-background-radius: 8;"/>

                    <!-- Table wrapped in a card -->
                    <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS"
                          style="-fx-padding: 0; -fx-background-radius: 14; -fx-border-radius: 14;">

                        <!-- Card top bar: title + count + Export + Add button -->
                        <HBox style="-fx-padding: 14 20;  -fx-border-width: 0 0 1 0;"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="📋  Liste des cours"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; "/>
                            <Label fx:id="countLabel" text=""
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"
                                   HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            
                            <!-- Multi-criteria filters -->
                            <ComboBox fx:id="filterStatusBox" promptText="Statut" styleClass="combo-box" style="-fx-pref-width: 100; -fx-font-size: 11px;"/>
                            <ComboBox fx:id="filterModuleBox" promptText="Module" styleClass="combo-box" style="-fx-pref-width: 120; -fx-font-size: 11px;"/>
                            
                            <Button text="🧾 Exporter PDF" onAction="#handleExport"
                                    styleClass="btn-secondary" style="-fx-padding: 6 12; -fx-font-size: 12px;"/>
                            <Button text="➕  Nouveau Cours" onAction="#handleOpenAdd"
                                    styleClass="btn-primary" style="-fx-padding: 8 16; -fx-font-size: 12px;"/>
                        </HBox>

                        <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS" styleClass="table-view"
                                   style="-fx-background-radius: 0 0 14 14; -fx-border-radius: 0 0 14 14; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="favoriteColumn"    text="★"          prefWidth="35"  minWidth="35"/>
                                <TableColumn fx:id="idColumn"          text="ID"          prefWidth="55"  minWidth="50"/>
                                <TableColumn fx:id="titleColumn"       text="Titre"        prefWidth="160" minWidth="120"/>
                                <TableColumn fx:id="moduleColumn"      text="Module"       prefWidth="140" minWidth="100"/>
                                <TableColumn fx:id="priceColumn"       text="Prix"         prefWidth="70"  minWidth="60"/>
                                <TableColumn fx:id="ratingColumn"      text="Note"         prefWidth="70"  minWidth="60"/>
                                <TableColumn fx:id="createdAtColumn"   text="Créé le"      prefWidth="120" minWidth="100"/>
                                <TableColumn fx:id="statusColumn"      text="Statut"       prefWidth="100" minWidth="80"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8">
                                    <Label text="📭" style="-fx-font-size: 32px;"/>
                                    <Label text="Aucun cours trouvé"
                                           style="-fx-font-size: 13px; -fx-text-fill: #94A3B8;"/>
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>

                <!-- ── Form Panel (hidden initially, slides in from right) ── -->
                <VBox fx:id="formPanel" styleClass="form-panel" spacing="14"
                      minWidth="310" prefWidth="320" maxWidth="330"
                      visible="false" managed="false">

                    <!-- Panel header with close button -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label fx:id="formPanelIcon" text="✏️" style="-fx-font-size: 16px;"/>
                        <Label fx:id="formPanelTitle" text="Nouveau Cours"
                               styleClass="form-panel-title" HBox.hgrow="ALWAYS"/>
                        <!-- Close / slide-out button -->
                        <Button text="✕" onAction="#handleClosePanel"
                                styleClass="btn-close-panel"/>
                    </HBox>
                    <Separator/>

                    <!-- Titre -->
                    <VBox spacing="5">
                        <Label text="TITRE *" styleClass="form-label"/>
                        <TextField fx:id="titleField" promptText="Titre du cours" styleClass="text-field"/>
                    </VBox>

                    <!-- AI Suggestion label -->
                    <Label fx:id="aiSuggestionLabel" text="💡 Astuce: Un prix entre 30€ et 50€ est recommandé."
                           wrapText="true"
                           style="-fx-font-size: 11px; -fx-text-fill: #4F46E5; -fx-background-color: rgba(79,70,229,0.1); -fx-padding: 6 10; -fx-background-radius: 6;"/>

                    <!-- Prix -->
                    <VBox spacing="5">
                        <Label text="PRIX (€) *" styleClass="form-label"/>
                        <TextField fx:id="priceField" promptText="ex: 99.99" styleClass="text-field"/>
                    </VBox>

                    <!-- Coefficient -->
                    <VBox spacing="5">
                        <Label text="COEFFICIENT" styleClass="form-label"/>
                        <TextField fx:id="coefficientField" promptText="ex: 1.5" styleClass="text-field"/>
                    </VBox>

                    <!-- Description -->
                    <VBox spacing="5" VBox.vgrow="ALWAYS">
                        <Label text="DESCRIPTION" styleClass="form-label"/>
                        <TextArea fx:id="descriptionArea" promptText="Description du cours..."
                                  styleClass="text-area" prefHeight="80" wrapText="true"/>
                    </VBox>

                    <!-- Module -->
                    <VBox spacing="5">
                        <Label text="MODULE" styleClass="form-label"/>
                        <ComboBox fx:id="moduleComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                    </VBox>

                    <!-- Statut -->
                    <VBox spacing="5">
                        <Label text="STATUT" styleClass="form-label"/>
                        <ComboBox fx:id="statusComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                    </VBox>

                    <Separator/>

                    <!-- Action buttons -->
                    <HBox spacing="8">
                        <Button fx:id="createBtn"  text="➕  Créer"    onAction="#handleCreate"
                                styleClass="btn-primary"   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="updateBtn"  text="✏  Modifier" onAction="#handleUpdate"
                                styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <HBox spacing="8">
                        <Button text="🗑  Supprimer" onAction="#handleDelete"
                                styleClass="btn-danger"    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <!-- ── Activity Panel ────────────────────────────────── -->
                <VBox styleClass="card" spacing="10" minWidth="260" prefWidth="260" maxWidth="260" VBox.vgrow="ALWAYS"
                      style="-fx-padding: 14; -fx-background-radius: 14; -fx-border-radius: 14;">
                    <Label text="⏱  Activité Récente" style="-fx-font-size: 14px; -fx-font-weight: bold; "/>
                    <Separator/>
                    <ListView fx:id="activityList" VBox.vgrow="ALWAYS" 
                              style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                </VBox>

            </HBox>
        </VBox>
    </center>

</BorderPane>
