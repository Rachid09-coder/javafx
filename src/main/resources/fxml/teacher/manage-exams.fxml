<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.ManageExamsController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard"/>
                <Button text="📚  Gérer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="📦  Gérer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="📝  Gérer Examens" styleClass="nav-button active" onAction="#handleManageExams"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShopManagement"/>
                <Button text="📊  Bulletins" styleClass="nav-button" onAction="#handleBulletins"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertifications"/>
                <Button text="🤖  Analyse AI" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="👥  Gestion des Élèves" styleClass="nav-button" onAction="#handleStudentManagement"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" pannable="true" styleClass="content-scroll">
        <HBox styleClass="content-area" spacing="16">

            <!-- Table -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Gérer les Examens" styleClass="page-title" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" promptText="🔍 Rechercher..." styleClass="search-bar" onAction="#handleSearch"/>
                </HBox>

                <Label fx:id="messageLabel" visible="false" wrapText="true"/>

                <TableView fx:id="examsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="titleColumn" text="Titre" prefWidth="220"/>
                        <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
                        <TableColumn fx:id="durationColumn" text="Durée" prefWidth="80"/>
                        <TableColumn fx:id="semesterColumn" text="Sem." prefWidth="70"/>
                        <TableColumn fx:id="coefficientColumn" text="Coeff." prefWidth="80"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucun examen" style="-fx-text-fill: #94A3B8;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Form -->
            <VBox styleClass="card" spacing="12" minWidth="320" prefWidth="340" maxWidth="360">
                <Label text="Formulaire Examen" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"/>
                <Separator/>

                <VBox spacing="4">
                    <Label text="Titre *" styleClass="form-label"/>
                    <TextField fx:id="titleField" promptText="Titre de l'examen" styleClass="text-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Type *" styleClass="form-label"/>
                    <ComboBox fx:id="typeComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Durée (minutes)" styleClass="form-label"/>
                    <TextField fx:id="durationField" promptText="ex: 90" styleClass="text-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Catégorie note" styleClass="form-label"/>
                    <ComboBox fx:id="gradeCategoryComboBox" maxWidth="Infinity" styleClass="combo-box"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Description" styleClass="form-label"/>
                    <TextArea fx:id="descriptionArea" promptText="Description..." styleClass="text-area" prefHeight="80" wrapText="true"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Année académique" styleClass="form-label"/>
                    <TextField fx:id="academicYearField" promptText="ex: 2025/2026" styleClass="text-field"/>
                </VBox>

                <HBox spacing="8">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Semestre" styleClass="form-label"/>
                        <TextField fx:id="semesterField" promptText="ex: 1" styleClass="text-field"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Coefficient" styleClass="form-label"/>
                        <TextField fx:id="coefficientField" promptText="ex: 2" styleClass="text-field"/>
                    </VBox>
                </HBox>

                <VBox spacing="4">
                    <Label text="Chemin fichier" styleClass="form-label"/>
                    <TextField fx:id="filePathField" promptText="file_path" styleClass="text-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Lien externe" styleClass="form-label"/>
                    <TextField fx:id="externalLinkField" promptText="external_link" styleClass="text-field"/>
                </VBox>

                <Separator/>
                <HBox spacing="8">
                    <Button text="➕ Créer" onAction="#handleCreate" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="✏ Modifier" onAction="#handleUpdate" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
                <HBox spacing="8">
                    <Button text="🗑 Supprimer" onAction="#handleDelete" styleClass="btn-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="✖ Effacer" onAction="#handleClear" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>

        </HBox>
        </ScrollPane>
    </center>
</BorderPane>
