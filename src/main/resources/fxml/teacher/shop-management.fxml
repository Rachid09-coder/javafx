<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.ShopManagementController">

    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard"/>
                <Button text="📚  Gérer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="📦  Gérer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="📝  Gérer Examens" styleClass="nav-button" onAction="#handleManageExams"/>
                <Button text="📊  Notes" styleClass="nav-button" onAction="#handleGradeManagement"/>
                <Button text="🛒  Boutique" styleClass="nav-button active" onAction="#handleShopManagement"/>
                <Button text="🏷  Catégories" styleClass="nav-button" onAction="#handleCategoryManagement"/>
                <Button text="📋  Bulletins" styleClass="nav-button" onAction="#handleBulletins"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertifications"/>
                <Button text="🤖  Analyse AI" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="👥  Gestion des Élèves" styleClass="nav-button" onAction="#handleStudentManagement"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content-area" spacing="16">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="🛒 Gestion de la Boutique" styleClass="page-title" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="🔍 Rechercher..." styleClass="search-bar" onAction="#handleSearch"/>
                <Button text="➕ Ajouter Produit" styleClass="btn-primary" onAction="#handleAdd"/>
                <Button text="🏷 Code promo" styleClass="btn-purple" onAction="#handleAddPromoCode"/>
                <Button text="✏ Modifier" styleClass="btn-secondary" onAction="#handleEdit"/>
                <Button text="🗑 Supprimer" styleClass="btn-danger" onAction="#handleDelete"/>
            </HBox>

            <Label fx:id="messageLabel" visible="false" wrapText="true"/>

            <TableView fx:id="productsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="idColumn"       text="ID"        prefWidth="50" />
                    <TableColumn fx:id="nameColumn"     text="Nom"       prefWidth="220"/>
                    <TableColumn fx:id="priceColumn"    text="Prix (DT)" prefWidth="100"/>
                    <TableColumn fx:id="stockColumn"    text="Stock"     prefWidth="80" />
                    <TableColumn fx:id="categoryColumn" text="Catégorie" prefWidth="150"/>
                </columns>
                <placeholder>
                    <Label text="Aucun produit" style="-fx-text-fill: #94A3B8;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>
