<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.ManageModulesController">

    <!-- ══ Sidebar ══════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" prefHeight="800">
            <VBox styleClass="sidebar-logo" spacing="3">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="NAVIGATION" styleClass="sidebar-section-label"/>
                <Button text="🏠   Tableau de bord"    styleClass="nav-button"        onAction="#handleDashboard"/>
                <Button text="📚   Gérer les Cours"    styleClass="nav-button"        onAction="#handleManageCourses"/>
                <Button text="📦   Gérer les Modules"  styleClass="nav-button active" onAction="#handleManageModules"/>
                <Button text="📝   Gérer Examens"      styleClass="nav-button"        onAction="#handleManageExams"/>
                <Button text="🛒   Boutique"           styleClass="nav-button"        onAction="#handleShopManagement"/>
                <Button text="📊   Bulletins"          styleClass="nav-button"        onAction="#handleBulletins"/>
                <Button text="🏆   Certifications"     styleClass="nav-button"        onAction="#handleCertifications"/>
                <Button text="🤖   Analyse AI"         styleClass="nav-button"        onAction="#handleAnalysisAI"/>
                <Button text="👥   Gestion des Élèves" styleClass="nav-button"        onAction="#handleStudentManagement"/>
            </VBox>
            <VBox styleClass="sidebar-footer">
                <Button text="🚪   Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <!-- ══ Main Content ═════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color: #F1F5F9;">

            <!-- Top header -->
            <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Gérer les Modules" styleClass="page-title"/>
                    <Label text="Organisez vos modules de cours" styleClass="page-subtitle"/>
                </VBox>
                <ComboBox fx:id="sortComboBox" promptText="Trier par..." styleClass="combo-box"
                          style=" -fx-pref-width: 170;"/>
                <TextField fx:id="searchField" promptText="🔍  Rechercher un module..."
                           styleClass="search-bar" onAction="#handleSearch"/>
                <Button text="🌙 Mode Sombre" onAction="#handleToggleTheme"
                        styleClass="btn-secondary" style="-fx-padding: 8 16; -fx-font-size: 12px;"/>
            </HBox>

            <!-- Body -->
            <HBox styleClass="content-area" spacing="20" VBox.vgrow="ALWAYS">

                <!-- ── Table Card ──────────────────────────────── -->
                <VBox spacing="14" HBox.hgrow="ALWAYS">

                    <!-- ── Analytics Dashboard ─────────────────────── -->
                    <HBox spacing="14">
                        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="📦" style="-fx-font-size: 20px;"/>
                            <Label fx:id="totalModulesStat" text="—" style="-fx-font-size: 18px; -fx-font-weight: bold; "/>
                            <Label text="Total Modules" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="🔗" style="-fx-font-size: 20px;"/>
                            <Label fx:id="totalLinkedCoursesStat" text="—" style="-fx-font-size: 18px; -fx-font-weight: bold; "/>
                            <Label text="Cours Associés" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="💶" style="-fx-font-size: 20px;"/>
                            <Label fx:id="avgModulePriceStat" text="—" style="-fx-font-size: 18px; -fx-font-weight: bold; "/>
                            <Label text="Prix Moyen / Module" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="4" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="🏷️" style="-fx-font-size: 20px;"/>
                            <Label fx:id="popularTagStat" text="—" style="-fx-font-size: 18px; -fx-font-weight: bold; "/>
                            <Label text="Tag Populaire" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="messageLabel" visible="false" wrapText="true"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 14; -fx-background-radius: 8;"/>

                    <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS"
                          style="-fx-padding: 0; -fx-background-radius: 14; -fx-border-radius: 14;">

                        <!-- Card top bar: title + count + Export + Add button -->
                        <HBox style="-fx-padding: 14 20;  -fx-border-width: 0 0 1 0;"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="📦  Liste des modules"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; "/>
                            <Label fx:id="countLabel" text=""
                                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"
                                   HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            
                            <!-- Tags Filter -->
                            <ComboBox fx:id="filterTagBox" promptText="Tous les tags" styleClass="combo-box" style="-fx-pref-width: 120; -fx-font-size: 11px;"/>
                            
                            <Button text="🧾 Exporter PDF" onAction="#handleExport"
                                    styleClass="btn-secondary" style="-fx-padding: 6 12; -fx-font-size: 12px;"/>
                            <!-- Triggers slide-in with empty form -->
                            <Button text="➕  Nouveau Module"
                                    onAction="#handleOpenAdd"
                                    styleClass="btn-primary"
                                    style="-fx-padding: 8 16; -fx-font-size: 12px;"/>
                        </HBox>

                        <TableView fx:id="modulesTable" VBox.vgrow="ALWAYS" styleClass="table-view"
                                   style="-fx-background-radius: 0 0 14 14; -fx-border-radius: 0 0 14 14; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="idColumn"          text="ID"           prefWidth="50"  minWidth="40"/>
                                <TableColumn fx:id="titleColumn"       text="Titre"        prefWidth="200" minWidth="120"/>
                                <TableColumn fx:id="tagsColumn"        text="Tags"         prefWidth="100" minWidth="80"/>
                                <TableColumn fx:id="courseCountColumn" text="Cours"        prefWidth="80"  minWidth="60"/>
                                <TableColumn fx:id="avgPriceColumn"    text="Prix Moy"     prefWidth="80"  minWidth="60"/>
                                <TableColumn fx:id="createdAtColumn"   text="Créé le"      prefWidth="130" minWidth="100"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8">
                                    <Label text="📭" style="-fx-font-size: 32px;"/>
                                    <Label text="Aucun module trouvé"
                                           style="-fx-font-size: 13px; -fx-text-fill: #94A3B8;"/>
                                </VBox>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>

                <!-- ── Form Panel (hidden initially, slides in from right) ── -->
                <VBox fx:id="formPanel" styleClass="form-panel" spacing="14"
                      minWidth="310" prefWidth="320" maxWidth="330"
                      visible="false" managed="false">

                    <!-- Panel header with close button -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="📦" style="-fx-font-size: 16px;"/>
                        <Label fx:id="formPanelTitle" text="Nouveau Module"
                               styleClass="form-panel-title" HBox.hgrow="ALWAYS"/>
                        <Button text="✕" onAction="#handleClosePanel"
                                styleClass="btn-close-panel"/>
                    </HBox>
                    <Separator/>

                    <VBox spacing="5">
                        <Label text="TITRE *" styleClass="form-label"/>
                        <TextField fx:id="titleField" promptText="Titre du module" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="TAGS (séparés par virgule)" styleClass="form-label"/>
                        <TextField fx:id="tagsField" promptText="ex: Programmation, Débutant" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="MINIATURE (URL / CHEMIN)" styleClass="form-label"/>
                        <TextField fx:id="thumbnailField" promptText="ex: images/module.png" styleClass="text-field"/>
                    </VBox>

                    <VBox spacing="5" VBox.vgrow="ALWAYS">
                        <Label text="DESCRIPTION" styleClass="form-label"/>
                        <TextArea fx:id="descriptionArea" promptText="Description du module..."
                                  styleClass="text-area" prefHeight="100" wrapText="true"/>
                    </VBox>

                    <Separator/>
                    <HBox spacing="8">
                        <Button fx:id="createBtn"  text="➕  Créer"    onAction="#handleCreate"
                                styleClass="btn-primary"   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button fx:id="updateBtn"  text="✏  Modifier" onAction="#handleUpdate"
                                styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <HBox spacing="8">
                        <Button text="🗑  Supprimer" onAction="#handleDelete"
                                styleClass="btn-danger"    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <!-- ── Activity Panel ────────────────────────────────── -->
                <VBox styleClass="card" spacing="10" minWidth="260" prefWidth="260" maxWidth="260" VBox.vgrow="ALWAYS"
                      style="-fx-padding: 14; -fx-background-radius: 14; -fx-border-radius: 14;">
                    <Label text="⏱  Activité Récente" style="-fx-font-size: 14px; -fx-font-weight: bold; "/>
                    <Separator/>
                    <ListView fx:id="activityList" VBox.vgrow="ALWAYS" 
                              style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                </VBox>

            </HBox>
        </VBox>
    </center>

</BorderPane>
