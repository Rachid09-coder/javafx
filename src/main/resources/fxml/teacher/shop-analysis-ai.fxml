<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            styleClass="main-container"
            fx:controller="com.edusmart.controller.teacher.ShopAnalysisAIController">

    <left>
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-logo" spacing="2">
                <Label text="🎓 EduSmart" styleClass="sidebar-logo-text"/>
                <Label text="Espace Enseignant" styleClass="sidebar-logo-subtitle"/>
            </VBox>
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Label text="MENU" styleClass="sidebar-section-label"/>
                <Button text="🏠  Tableau de bord" styleClass="nav-button" onAction="#handleDashboard"/>
                <Button text="📚  Gérer les Cours" styleClass="nav-button" onAction="#handleManageCourses"/>
                <Button text="📦  Gérer les Modules" styleClass="nav-button" onAction="#handleManageModules"/>
                <Button text="📝  Gérer Examens" styleClass="nav-button" onAction="#handleManageExams"/>
                <Button text="📊  Notes" styleClass="nav-button" onAction="#handleGradeManagement"/>
                <Button text="🛒  Boutique" styleClass="nav-button" onAction="#handleShopManagement"/>
                <Button text="🏷  Catégories" styleClass="nav-button" onAction="#handleCategoryManagement"/>
                <Button text="📋  Bulletins" styleClass="nav-button" onAction="#handleBulletins"/>
                <Button text="🏆  Certifications" styleClass="nav-button" onAction="#handleCertifications"/>
                <Button text="🤖  Analyse AI (Étudiants)" styleClass="nav-button" onAction="#handleAnalysisAI"/>
                <Button text="🤖  Analyse AI (Boutique)" styleClass="nav-button active" />
                <Button text="👥  Gestion des Élèves" styleClass="nav-button" onAction="#handleStudentManagement"/>
            </VBox>
            <VBox style="-fx-padding: 16 0 24 0;">
                <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>
                <Button text="🚪  Déconnexion" styleClass="nav-button" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content-area" spacing="24">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="🤖 Analyse des Ventes avec Gemini IA" styleClass="page-title" HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Générer Analyse" styleClass="btn-primary" onAction="#handleGenerateAnalysis"/>
            </HBox>

            <VBox spacing="16" VBox.vgrow="ALWAYS" styleClass="form-card">
                <Label text="Insights Business &amp; Recommandations" styleClass="section-title"/>
                <Label text="L'IA Gemini va analyser vos commandes récentes et les articles vendus pour vous fournir des statistiques (chiffre d'affaires, meilleures ventes) et des recommandations actionnables." style="-fx-text-fill: #64748b; -fx-wrap-text: true;"/>
                
                <Label fx:id="messageLabel" visible="true" wrapText="true" style="-fx-font-weight: bold;"/>
                
                <StackPane VBox.vgrow="ALWAYS">
                    <TextArea fx:id="analysisTextArea" styleClass="text-area-modern" wrapText="true" editable="false"/>
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="50" maxHeight="50"/>
                </StackPane>
            </VBox>
        </VBox>
    </center>
</BorderPane>
