<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.edusmart.controller.shared.ProfileController"
      style="-fx-background-color: #F8FAFC; -fx-pref-width: 600;">
    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <!-- Top Navigation -->
    <HBox>
        <Button text="⬅ Retour" onAction="#handleCancel" 
                style="-fx-background-color: #E2E8F0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 5;"/>
    </HBox>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <StackPane>
            <Circle radius="40" fill="#6366F1"/>
            <Label text="👤" style="-fx-text-fill: white; -fx-font-size: 40;"/>
        </StackPane>
        <VBox spacing="5">
            <Label fx:id="nameTitleLabel" text="Mon Profil" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            <Label fx:id="roleLabel" text="Étudiant" style="-fx-text-fill: #64748B; -fx-font-size: 14;"/>
        </VBox>
    </HBox>

    <Separator/>

    <!-- Content -->
    <GridPane vgap="15" hgap="20">
        <columnConstraints>
            <ColumnConstraints minWidth="150" prefWidth="150"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <!-- First Name -->
        <Label text="Prénom" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="input-field" 
                   style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>

        <!-- Last Name -->
        <Label text="Nom" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <TextField fx:id="lastNameField" GridPane.rowIndex="1" GridPane.columnIndex="1" 
                   style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>

        <!-- Primary Email -->
        <Label text="Email Principal" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <TextField fx:id="emailField" editable="false" GridPane.rowIndex="2" GridPane.columnIndex="1" 
                   style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-text-fill: #64748B;"/>

        <!-- Associated Email (NEW) -->
        <VBox spacing="2" GridPane.rowIndex="3" GridPane.columnIndex="0">
            <Label text="Email Associé" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
            <Label text="(Récupération)" style="-fx-font-size: 10; -fx-text-fill: #94A3B8;"/>
        </VBox>
        <TextField fx:id="emailAssocField" promptText="email@recuperation.com" GridPane.rowIndex="3" GridPane.columnIndex="1" 
                   style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #6366F1; -fx-border-radius: 8; -fx-border-width: 1.5;"/>

        <!-- Password -->
        <Label text="Nouveau Mot de Passe" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <PasswordField fx:id="passwordField" promptText="Laisser vide pour ne pas changer" GridPane.rowIndex="4" GridPane.columnIndex="1" 
                       style="-fx-background-radius: 8; -fx-padding: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8;"/>
                       
        <!-- Signature Pad -->
        <VBox spacing="5" GridPane.rowIndex="5" GridPane.columnIndex="0">
            <Label text="Signature Numérique" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
            <Label text="(Pour bulletins/certifs)" style="-fx-font-size: 10; -fx-text-fill: #94A3B8;"/>
            <Button text="Effacer" onAction="#handleClearSignature" style="-fx-font-size: 10; -fx-background-color: #FEE2E2; -fx-text-fill: #EF4444; -fx-background-radius: 4; -fx-padding: 4 8;"/>
        </VBox>
        <VBox spacing="10" GridPane.rowIndex="5" GridPane.columnIndex="1">
            <StackPane style="-fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-color: white; -fx-background-radius: 8;">
                <javafx.scene.canvas.Canvas fx:id="signatureCanvas" width="400" height="150"
                     onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged"/>
            </StackPane>
        </VBox>
    </GridPane>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Actions -->
    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel" 
                style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-padding: 10 20;"/>
        <Button text="Enregistrer les modifications" onAction="#handleSave" 
                style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 8;"/>
    </HBox>
</VBox>
